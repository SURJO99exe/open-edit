{
  "name": "ai-editor",
  "version": "1.0.0",
  "description": "AI Code Editor built with Electron + Vite + React + TypeScript",
  "author": "Dev Surjo",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:electron": "wait-on tcp:5174 && tsx electron/main.ts",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "build:frontend": "npm run build --prefix frontend",
    "build:electron": "tsc -p electron/tsconfig.json",
    "dist": "npm run build:frontend && npm run build:electron && electron-builder"
  },
  "build": {
    "appId": "com.aieditor.app",
    "productName": "AI Editor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "37.0.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "axios": "^1.16.1"
  }
}
